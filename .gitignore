.DS_Store
.env
.venv/
__pycache__/
*.pyc
data/items.jsonl
data/items.jsonl.*
data/items.non_manga.jsonl
data/series_aliases.json
data/items.non_collectible.jsonl
data/state.json
data/state.json.bak*
data/feedback.jsonl
data/approvals.jsonl
data/edits.jsonl
data/dup_decisions.jsonl
data/*.broken.json
data/images/
data/backups/
backups/
data/diagnostics/
reports/
logs/
.claude/scheduled_tasks.lock

# Artefacto regenerable de la cola de revisión de portadas (familia items.jsonl)
data/cover_preview.json

# Historial de intentos de búsqueda de portadas (estado local, no versionar)
data/cover_search_attempts.jsonl

# Ledger de rechazos de portadas / denylist (append-only, estado local)
data/cover_rejections.jsonl

# Reporte regenerable de la auditoría de calidad (lo genera data_quality.py)
data/quality_report.json

# Archivos de progreso de scripts largos (estado de runtime, no versionar)
data/*_progress.json
data/standardize-progress.json

# Dependencias de Node (regenerables con npm install — nunca versionar)
node_modules/

# Temporales de orquestación de scripts (cover-search, etc.)
.tmp_sc_*

# Backups ad-hoc de archivos de data que dejan algunos retrofits (.bak-* / .pre-*-bak)
data/*.bak-*
data/*.pre-*-bak
