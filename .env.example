# --- Notificaciones Telegram (opcional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Search discovery (opcional, usado por scripts/retrofit/search_discovery.py) ---
# Gemini API con "Grounding with Google Search" tool.
# Reemplaza al viejo Custom Search JSON API (cerrado a nuevos clientes en 2025).
#
# Setup:
#   1. Andate a https://aistudio.google.com (NO Google Cloud Console).
#   2. Click "Get API key" → genera key tipo "AIzaSy..."
#   3. Pegala aquí abajo.
# Free tier 2026: Gemini 2.5 Flash = 500 RPD compartido + 15 RPM.
# Sin tarjeta. Devuelve URLs reales del index de Google (grounding chunks).
GEMINI_API_KEY=
# Opcional: cambiar modelo (default gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# Tavily Search API (fallback cuando Gemini agota quota).
# 1,000 búsquedas/mes free, sin tarjeta.
# Obtenela en https://tavily.com → Sign up → API key tipo "tvly-...".
TAVILY_API_KEY=
