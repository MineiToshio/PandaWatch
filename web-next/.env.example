# --- PandaWatch App (web-next) — environment ---

# Public origin of the deployed app. Used for sitemap, canonical tags, OG/Twitter URLs.
# Production (set in Vercel → Project → Settings → Environment Variables, Production scope):
NEXT_PUBLIC_SITE_URL=https://watch.pandatrack.app
#
# Preview / dev: leave unset. lib/seo.ts falls back to Vercel's injected
# VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL, then to http://localhost:3000.

# Ruta al corpus JSONL. Default: ../data/items.jsonl (relativa a web-next/ en el
# monorepo local). Sobreescribir sólo si el corpus vive en otra ubicación
# (deploy / CI — p.ej. una copia que baja el prebuild). Pendiente: migración a
# DB reemplaza esta lectura de archivo.
# ITEMS_PATH=/ruta/absoluta/a/items.jsonl

# Ruta al índice de aliases de series (series_aliases.json). Default: junto al
# items.jsonl (dirname(ITEMS_PATH)). Sobreescribir sólo si vive aparte.
# ALIASES_PATH=/ruta/absoluta/a/series_aliases.json

# Base pública del espejo de imágenes para el deploy (bucket R2 — "Image storage
# Fase 2" en CLAUDE.md). Si se setea, las imágenes locales se resuelven contra
# este base (CoverImage + OG + JSON-LD) en vez del symlink public/images.
# Dejar SIN setear en local: se usa el symlink ../../data/images/ como hoy.
# Prefijo NEXT_PUBLIC_ para que funcione en el client (CoverImage) y en el server.
# NEXT_PUBLIC_IMAGE_BASE_URL=https://images.watch.pandatrack.app
